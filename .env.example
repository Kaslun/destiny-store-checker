# ─────────────────────────────────────────────────────────────────────────────
# Everywherse environment. Copy to .env.local for dev. NEVER commit real values.
# Naming is a security control: only NEXT_PUBLIC_* is allowed into the browser.
# ─────────────────────────────────────────────────────────────────────────────

# --- Bungie OAuth (confidential client) ---
BUNGIE_CLIENT_ID=
BUNGIE_CLIENT_SECRET=          # crown jewel — server only
BUNGIE_API_KEY=                # sensitive — server only

# --- Token encryption (AES-256-GCM) ---
# 32 random bytes, base64. Generate: openssl rand -base64 32
# Losing this makes every stored token undecryptable. Back it up separately.
TOKEN_ENC_KEY=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=     # bypasses RLS — treat like a root password, server only

# --- Session ---
# Signs/encrypts the session cookie. Generate: openssl rand -base64 32
SESSION_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
NOTIFY_FROM_EMAIL=Everywherse <notify@example.com>

# --- Web push (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# --- App ---
APP_URL=https://127.0.0.1:3000   # https origin; used to build the OAuth redirect_uri

# --- Client-readable (safe ONLY because private tables deny anon) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=    # same value as VAPID_PUBLIC_KEY; needed client-side to subscribe
